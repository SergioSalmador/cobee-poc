digraph G {
  rankdir=LR;
  graph [fontname="Arial", bgcolor="white", pad="0.2", nodesep="0.55", ranksep="0.55"];
  node [shape=box, style="rounded,filled", color="#1f2937", fillcolor="#f8fafc", fontname="Arial", fontsize=11];
  edge [color="#334155", penwidth=1.2, arrowsize=0.7];

  rds [label="RDS\nmanage_master_user_password=true"];
  sm [label="Secrets Manager\n(secret ARN)"];
  irsa [label="IRSA Role\n(read secret policy)"];
  ext [label="ExternalSecret"];
  k8s [label="Kubernetes Secret"];
  pod [label="go-webapp Pod"];

  rds -> sm;
  irsa -> sm [label="GetSecretValue", fontsize=9];
  ext -> k8s;
  k8s -> pod;
  pod -> ext [style=dashed, label="sync loop", fontsize=9];
}
